{
  "name": "convo",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "format:fix": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "bun run lint:frontend",
    "lint:frontend": "bun run --cwd frontend lint",
    "test:backend": "bun run --cwd backend test:jwt",
    "build:backend": "bun run --cwd backend build",
    "build:frontend": "bun run --cwd frontend build",
    "check": "bun run format:check && bun run lint && bun run test:backend && bun run build:backend && bun run build:frontend",
    "precommit": "bun run format:check && bun run lint",
    "prepush": "bun run check"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.5.3"
  }
}
