# CHANGE BEFORE DEPLOY
# Local default:
# - Caddy serves https://localhost with an internal development certificate.
# Production:
# - Set PUBLIC_DOMAIN to your real domain.
# - Set PUBLIC_ORIGIN and FRONTEND_ORIGIN to https://your-domain.
# - FRONTEND_ORIGIN also accepts a comma-separated allowlist when needed.
# - Set TLS_DIRECTIVE= so Caddy uses Let's Encrypt instead of local internal TLS.
PUBLIC_DOMAIN=localhost
PUBLIC_ORIGIN=https://localhost
FRONTEND_ORIGIN=https://localhost
TLS_DIRECTIVE=tls internal

POSTGRES_DB=convo_db
POSTGRES_USER=convo
POSTGRES_PASSWORD=change-me-long-random-password


# Generate fresh deployment keys.
# openssl ecparam -name prime256v1 -genkey -noout -out ec-private.pem
# openssl pkcs8 -topk8 -nocrypt -in ec-private.pem -out jwt-private.pem
# openssl ec -in ec-private.pem -pubout -out jwt-public.pem
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-private-key\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nreplace-with-public-key\n-----END PUBLIC KEY-----\n"


# ---------------------------------------------------------------------------------------------------------------
# For backend outside Docker.
DATABASE_URL=postgres://convo:change-me-long-random-password@localhost:5532/convo_db

# USUALLY KEEP AS IS
NODE_ENV=production
PORT=9173
JWT_ISSUER=convo-auth
JWT_AUDIENCE=convo-web
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
VITE_API_BASE_URL=/api

# PORT BINDINGS
APP_HOST_BIND=0.0.0.0
HTTP_HOST_PORT=80
HTTPS_HOST_PORT=443
